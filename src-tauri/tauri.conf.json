{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Burrowstock",
  "version": "0.1.0",
  "identifier": "com.burrowstock.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Burrowstock",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "center": true,
        "decorations": true,
        "backgroundColor": "#111111"
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost bslocal:; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' bslocal: data: blob:; connect-src ipc: http://ipc.localhost https://generativelanguage.googleapis.com",
      "dangerousDisableAssetCspModification": false
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}